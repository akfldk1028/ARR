    },
    {
      "unit_type": "항",
      "unit_number": "6",
      "title": null,
      "content": "교육부장관은 법 제14조의3제6항에 따라 감염병 정보를 공개할 때에는 「정보통신망 이용촉진 및 정보보호 등에 관한 법률」 제2조제1항제1호에 따른 정보통신망에 게재하거나 보도자료를 배포하는 등의 방법으로 하여야 한다.",
      "unit_path": "제10조의3_6",
      "full_id": "학교보건법::제10조의3::6",
      "parent_id": "학교보건법::제10조의3",
      "order": 6,
      "revision_dates": [],
      "metadata": {}
    },
    {
      "unit_type": "항",
      "unit_number": "7",
      "title": null,
      "content": "제6항에 따른 정보의 당사자는 공개된 사항 중 사실과 다르거나 의견이 있는 경우 교육부장관에게 구두, 서면 등의 방법으로 이의신청을 할 수 있으며, 교육부장관은 이에 따라 공개된 정보의 정정 등 필요한 조치를 하여야 한다.",
      "unit_path": "제10조의3_7",
      "full_id": "학교보건법::제10조의3::7",
      "parent_id": "학교보건법::제10조의3",
      "order": 7,
      "revision_dates": [],
      "metadata": {}
